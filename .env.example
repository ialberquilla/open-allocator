# Copy to .env for local use:
#   cp .env.example .env && chmod 600 .env
#   uv run open-allocator ...
#

# -- 1Tx API ---------------------------------------------------------------
ONE_TX_API_URL=https://api.1tx.fi/api/v1
ONE_TX_API_KEY=replace-with-api-key

# -- 1Tx transaction options ----------------------------------------------
ONE_TX_SLIPPAGE_BPS=50
ONE_TX_FAST_TRANSFER=false

# Optional referral. Set both to apply; max fee is 500 bps.
# ONE_TX_REFERRAL_FEE_BPS=25
# ONE_TX_REFERRAL_WALLET=0x0000000000000000000000000000000000000000

# -- Signer ---------------------------------------------------------------
# How to sign and submit is three independent choices:
#
#   SIGNER_ACCOUNT=eoa|safe                 what holds the funds
#   SIGNER_SUBMISSION=rpc|erc4337-paymaster how the tx reaches the chain
#   SIGNER_OWNER=local|remote               where the signing key lives
#
#
# ONE_TX_PRIVATE_KEY is required only for a local-key EOA over RPC — a Safe
# signs with SAFE_PROPOSER_CREDENTIAL, a remote owner signs in the enclave.
SIGNER_ACCOUNT=eoa
SIGNER_SUBMISSION=rpc
SIGNER_OWNER=local

# You do not need to create a Safe in the UI. Give the seed and the address is
# derived counterfactually — the SAME address on every supported chain — and
# deployed on first use. `open-allocator safe-address` prints it.
#
# Owner ORDER matters: it feeds the address derivation. Reordering moves the
# Safe to a different address.
# SAFE_OWNERS=0xYourKey...,0xCoSigner...
# SAFE_THRESHOLD=2
# SAFE_SALT_NONCE=0
# SAFE_CHAIN_ID=8453
# SAFE_TRANSACTION_SERVICE_URL=https://safe-transaction-base.safe.global
# Set SAFE_ADDRESS instead to use a Safe that already exists.
# SAFE_ADDRESS=0x...

# -- Gas in USDC (SIGNER_SUBMISSION=erc4337-paymaster) ---------------------
# Pay gas in USDC out of your own funds instead of funding native gas on every
# chain. Self-custody is preserved: the paymaster fronts native gas to the
# EntryPoint and pulls USDC from your account.
#
# pimlico  — default, ~40 chains. Get a key at dashboard.pimlico.io
# circle   — 7 chains (Ethereum, Base, Arbitrum, OP, Polygon, Avalanche, Unichain)
# generic-http — a self-hosted or unlisted bundler
# PAYMASTER_PROVIDER=pimlico

# Pimlico's endpoint embeds the chain id, so the per-chain URL is derived from
# this key rather than configured per chain. Prefer the keychain over this file:
#   keyring set open-allocator PIMLICO_API_KEY
# PIMLICO_API_KEY=pim_...

# The smart account that holds the funds and pays gas. With SIGNER_ACCOUNT=safe
# this is the derived Safe (see safe-address) — leave the address unset and it is
# derived from SAFE_OWNERS/SAFE_THRESHOLD, so the two can never disagree.
# PAYMASTER_ACCOUNT_TYPE=safe
# PAYMASTER_ACCOUNT_ADDRESS=0x...
# The USDC the paymaster is paid in. Normally leave this unset: it is looked up
# per chain from the built-in registry. Override one chain — a bridged variant,
# or a chain with no row — with the per-chain form:
# PAYMASTER_USDC_ADDRESS_8453=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
#
# The bare form is the pre-registry setting, now read only for chains with no
# row: on a multi-chain run it names the wrong token everywhere else.
# PAYMASTER_USDC_ADDRESS=0x...

# PAYMASTER_SUPPORTED_CHAIN_IDS=8453,42161,143

# For generic-http only — pimlico derives these from PIMLICO_API_KEY.
# PAYMASTER_BUNDLER_URL=https://...
# PAYMASTER_BUNDLER_CREDENTIAL=...
# PAYMASTER_URL=https://...
# PAYMASTER_CREDENTIAL=...
# EntryPoint v0.7. A Safe cannot use v0.8: Safe4337Module pins its EntryPoint in
# an immutable constructor arg and the latest release (v0.3.0) is pinned to v0.7
# — verified on-chain. Unset, this defaults to v0.7 anyway.
# PAYMASTER_ENTRY_POINT=0x0000000071727De22E5E9d8BAf0edAc6f37da032

# -- RPC endpoints --------------------------------------------------------
# RPC_URL_<chainId> overrides the built-in public RPC default for that chain.
# Base mainnet has a built-in default; override it when you need a private RPC.
# RPC_URL_8453=https://mainnet.base.org
# RPC_URL_42161=https://arb1.arbitrum.io/rpc
